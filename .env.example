# ── Anthropic ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── SMTP (fill in your provider's values) ──────────
# Examples:
#   Brevo:    host=smtp-relay.brevo.com  port=587
#   Mailgun:  host=smtp.mailgun.org      port=587
#   Gmail:    host=smtp.gmail.com        port=465  secure=true
#   OVH:      host=ssl0.ovh.net          port=465  secure=true

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@omegapraxis.com
SMTP_PASS=your-smtp-password

# This is the From address shown to recipients
SMTP_FROM=contact@omegapraxis.com

# ── Server ─────────────────────────────────────────
PORT=3000

# ── Firestore ──────────────────────────────────────────────────
FIREBASE_PROJECT_ID=devgurucatdb
# Paste entire service account JSON as one line:
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"devgurucatdb",...}
